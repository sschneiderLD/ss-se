# LaunchDarkly SDK Key (server-side - keep secret!)
# Find in Project Settings > Environments > [Your env] > SDK Key
LD_SDK_KEY=your-sdk-key-here

# For kill switch trigger/recovery buttons - API token with Write access
# Find in Account settings > Authorization > Create token
LD_ACCESS_TOKEN=your-api-token-here

# Project key for the kill switch API (where the api-integration-kill-switch flag lives)
# Find in Project settings (gear icon) → Project key (e.g. "default")
LD_PROJECT_KEY=your-project-key

# Environment key for the kill switch API (e.g. test, production)
# Find in Project settings → Environments → key for your environment
LD_ENVIRONMENT_KEY=your-environment-key

# Optional: port (default 3001)
PORT=3001
